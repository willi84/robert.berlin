{
  "name": "robert.berlin",
  "version": "1.0.0",
  "description": "my website",
  "main": "index.html",
  "scripts": {
    "build:healthcheck_fast": "npm run build_app -- healthcheck --fast",
    "start:api": "tsx watch --clear-screen=false src/backend/apps/api/index.ts",
    "watch:api": "chokidar 'src/frontend' -c 'npm run build:api'",
    "watch:healthcheck": "chokidar 'src/frontend' -c 'npm run build:healthcheck_fast'",
    "dev:all": "npm-run-all --parallel start:api watch:api dev:eleventy dev:vite watch:healthcheck",
    "dev": "npm run build:healthcheck_fast && npm run dev:all",
    "build": "NODE_ENV=production npm run build_all",
    "build_all": "npm run build:api && npm run build:vite && npm run build:eleventy",
    "build:api": "npm run build_app -- api",
    "build_app": "sh -c 'tsx src/backend/apps/$1/index.ts $2' --",
    "start_app": "sh -c 'tsx watch --clear-screen=false src/backend/apps/$1/index.ts' --",
    "watch:healthcheck_fast": "chokidar 'src/frontend' -c 'npm run build:healthcheck_fast'",
    "test": "jest --env=jsdom --coverage --runInBand --verbose",
    "build:vite": "vite build --config vite.config.ts",
    "build:viteXX": "vite build --config vite.config.js",
    "build:eleventy": "eleventy --config=.eleventy.shim.js",
    "dev:vite": "vite",
    "dev:eleventy": "eleventy --config=.eleventy.shim.js --serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willi84/robert.berlin.git"
  },
  "keywords": [
    "website",
    "personal",
    "profile"
  ],
  "author": "Robert Willemelis",
  "license": "SEE LICENSE in LICENSE.md",
  "bugs": {
    "url": "https://github.com/willi84/robert.berlin/issues"
  },
  "homepage": "https://github.com/willi84/robert.berlin#readme",
  "devDependencies": {
    "@11ty/eleventy": "^1.0.0",
    "@types/jest": "^29.5.3",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "chokidar-cli": "^3.0.0",
    "jest": "^29.6.2",
    "jest-environment-jsdom": "^29.6.2",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^4.9.5",
    "vite": "^2.9.18"
  }
}
