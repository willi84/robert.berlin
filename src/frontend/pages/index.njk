---
layout: base.template.njk
title: Welcome to robert.berlin
navigation: true
footer: true
---

{%- from "./../templates/_setup/macros/component.macro.njk" import component -%}



{% set categories = all.categories | default([]) %}
{% set statusClasses = all.configuration.status | default({}) %}
{% set categoryLabels = {
    projects: '🗂️ Projekte',
    hackathons: '🚀 Hackathons',
    conferences: '🗓️ Konferenzen',
    workshops: '🎓 Workshops',
    tech: '💻 Tech'
} %}

<section class="portfolio-shell" data-portfolio data-view="cards" data-theme="dark">
    <div class="container py-4 py-lg-5">
        <header class="portfolio-header mb-4">
            <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <a class="portfolio-logo" href="/" aria-label="Startseite">
                        {{
                            component("image", {
                                image: main.logo.src,
                                class: "",
                                alt_prefix: main.logo.alt,
                                width: "50%",
                                height: "auto",
                                lazy: true
                            })
                        }}
                    </a>
                    <div>
                        <p class="portfolio-kicker mb-1">~/portfolio</p>
                        <h1 class="portfolio-title mb-1">Robert Willemelis</h1>
                        <p class="portfolio-subtitle mb-0">Projekte, Hackathons, Konferenzen und Workshops.  <span class="badge bg-warning">in Arbeit</span></p>
                    </div>
                </div>

                <div class="portfolio-actions d-flex flex-wrap gap-2">
                    <div class="btn-group btn-group-sm" role="group" aria-label="Ansicht wechseln">
                        <button class="btn btn-outline-light active" type="button" data-view-button="cards">▦ Cards</button>
                        <button class="btn btn-outline-light" type="button" data-view-button="list">☰ Liste</button>
                    </div>
                    {{
                        component("dropdown", {
                            values: [ 'light','green', 'red', 'dark', 'blue', 'yellow'],
                            defaultValue: "dark",
                            key: "bs-theme",
                            label: "Theme"
                        })
                    }}
                    
                </div>
            </div>
        </header>

        <nav class="portfolio-toolbar mb-4" aria-label="Portfolio Filter">
            <div class="row g-3 align-items-center">
                <div class="col-12 col-lg-8">
                    {{
                        component("search", {
                            label: "Portfolio durchsuchen",
                            class: "portfolio-input",
                            placeholder: "grep: Titel, Ort, Status, Tags …"
                        })
                    }}
                </div>
                <div class="col-12 col-lg-4 portfolio-actions">
                    {{
                        component("dropdown", {
                            values: [ 'date-desc','date-asc', 'title-asc', 'title-desc', 'status-asc', 'status-desc'],
                            defaultValue: "date-desc",
                            key: "bs-sort",
                            label: "Sortierung",
                            sort: "[data-category-section]"
                        })
                    }}
                </div>
                <div class="col-12 col-lg-12">
                    <div class="portfolio-filter-scroll gap-2 justify-content-lg-end" data-category-filter>
                        <button class="btn btn-sm mb-2 portfolio-filter active" type="button" data-filter-button="all">
                            Alle <span>{{ categories | length }}</span>
                        </button>
                        {% for category in categories %}
                            <button class="btn btn-sm mb-2 portfolio-filter" type="button" data-filter-button="{{ category }}">
                                {{ categoryLabels[category] | default(category) }} <span>{{ all.data[category] | length }}</span>
                            </button>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </nav>

        {% for category in categories %}
            <section class="portfolio-category mb-5" data-category-section="{{ category }}">
                <div class="portfolio-category-head d-flex align-items-end justify-content-between gap-3 mb-3">
                    <div>
                        {# <p class="portfolio-kicker mb-1">cat {{ loop.index }}</p> #}
                        <h2 class="h4 mb-0">{{ categoryLabels[category] | default(category) }}</h2>
                    </div>
                    <span class="portfolio-count">{{ all.data[category] | length }} items</span>
                </div>

                <div class="portfolio-grid">
                    {% for item in all.data[category] %}
                        {% set title = item.title | default(item['🔑name']) | default('Ohne Titel') %}
                        {% set name = item['🔑name'] | default(title) %}
                        {% set icon = item['🖼️'] | default('') %}
                        {% set screenshot = item.screenshot | default('') %}
                        {% set description = item.description | default('') %}
                        {% set status = item.status | default('') %}
                        {% set tags = item['🏷️ tags'] | default('') %}
                        {% set location = item['📍location'] | default('') %}
                        {% set country = item['🌐'] | default('') %}
                        {% set start = item.start | default('') %}
                        {% set end = item.end | default('') %}
                        {% set project = item.project | default('') %}
                        {% set result = item.ergebnis | default('') %}
                        {% set role = item.role | default('') %}
                        {% set conductor = item.conductor | default('') %}
                        {% set type = item.type | default('') %}
                        {% set url = item.url | default(item.website) | default('') %}
                        {% set code = item.code | default(item.github) | default('') %}
                        {% set pinned = item['📌'] == 'TRUE' %}
                        {% set statusClass = statusClasses[status] | default('text-bg-secondary') %}
                        {% set searchValue = (category ~ ' ' ~ title ~ ' ' ~ name ~ ' ' ~ description ~ ' ' ~ status ~ ' ' ~ tags ~ ' ' ~ location ~ ' ' ~ country ~ ' ' ~ project ~ ' ' ~ result ~ ' ' ~ role ~ ' ' ~ conductor ~ ' ' ~ type) | lower %}

                        <article
                            class="portfolio-item{% if pinned %} is-pinned{% endif %}"
                            data-search-item
                            data-category="{{ category }}"
                            data-search="{{ searchValue }}"
                            data-title="{{ title | lower }}"
                            data-status="{{ status | lower }}"
                            data-start="{{ start }}"
                            data-pinned="{% if pinned %}1{% else %}0{% endif %}">
                            <div class="portfolio-visual">
                                {% if screenshot %}
                                    <a href="{{ url or screenshot }}" {% if url %}target="_blank" rel="noopener noreferrer"{% endif %} aria-label="{{ title }} öffnen">
                                        <img class="portfolio-screenshot" src="{{ screenshot }}" alt="Screenshot von {{ title }}" loading="lazy">
                                    </a>
                                {% else %}
                                    <div class="portfolio-iconbox" aria-hidden="true">
                                        {% if icon %}
                                            <img src="{{ icon }}" alt="" loading="lazy">
                                        {% else %}
                                            <span>{{ title | first | upper }}</span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>

                            <div class="portfolio-content">
                                <div class="portfolio-item-top">
                                    <div class="min-w-0">
                                        <p class="portfolio-path mb-1">{{ category }}/{{ name | lower | replace(' ', '-') }}</p>
                                        <h3 class="portfolio-item-title mb-0">{{ title }}</h3>
                                    </div>
                                    {% if pinned %}<span class="portfolio-pin" title="Hervorgehoben">📌</span>{% endif %}
                                </div>

                                <div class="portfolio-badges">
                                    {% if status %}<span class="badge {{ statusClass }}">{{ status }}</span>{% endif %}
                                    {% if result %}<span class="badge text-bg-success">🏆 {{ result }}</span>{% endif %}
                                    {% if tags %}<span class="badge portfolio-muted-badge">{{ tags }}</span>{% endif %}
                                </div>

                                {% if description %}
                                    <p class="portfolio-description">{{ description }}</p>
                                {% endif %}

                                <dl class="portfolio-meta">
                                    {% if start %}
                                        <div><dt>date</dt><dd>{{ start }}{% if end %} – {{ end }}{% endif %}</dd></div>
                                    {% endif %}
                                    {% if location or country %}
                                        <div><dt>loc</dt><dd>{{ location }}{% if country %} / {{ country }}{% endif %}</dd></div>
                                    {% endif %}
                                    {% if project %}<div><dt>project</dt><dd>{{ project }}</dd></div>{% endif %}
                                    {% if role %}<div><dt>role</dt><dd>{{ role }}</dd></div>{% endif %}
                                    {% if conductor %}<div><dt>by</dt><dd>{{ conductor }}</dd></div>{% endif %}
                                    {% if type %}<div><dt>type</dt><dd>{{ type }}</dd></div>{% endif %}
                                </dl>

                                <div class="portfolio-links">
                                    {% if url %}<a class="btn btn-sm portfolio-link" href="{{ url }}" target="_blank" rel="noopener noreferrer">open ↗</a>{% endif %}
                                    {% if code %}<a class="btn btn-sm portfolio-link" href="{{ code }}" target="_blank" rel="noopener noreferrer">code</a>{% endif %}
                                    {% if item['pitch-video'] %}<a class="btn btn-sm portfolio-link" href="{{ item['pitch-video'] }}" target="_blank" rel="noopener noreferrer">video</a>{% endif %}
                                    {% if item['pitch-deck'] %}<a class="btn btn-sm portfolio-link" href="{{ item['pitch-deck'] }}" target="_blank" rel="noopener noreferrer">deck</a>{% endif %}
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            </section>
        {% endfor %}

        <p class="portfolio-empty d-none" data-search-empty>Keine passenden Einträge gefunden.</p>
    </div>
</section>
