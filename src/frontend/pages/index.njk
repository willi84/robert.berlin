---
layout: base.template.njk
title: Welcome to robert.berlin
navigation: true
footer: true
menu:
  label: Start
  emoji: 🏠
  order: 10
---

{%- from "./../templates/_setup/macros/component.macro.njk" import component -%}



{% set categories = all.categories | default([]) %}
{% set statusClasses = all.configuration.status | default({}) %}
{% set eventCategories = ['hackathons', 'conferences', 'workshops'] %}
{% set categoryLabels = {
    projects: '🗂️ Projekte',
    hackathons: '🚀 Hackathons',
    conferences: '🗓️ Konferenzen',
    workshops: '🎓 Workshops',
    tech: '💻 Tech'
} 
%}

<section class="portfolio-shell" data-portfolio data-view="cards" data-theme="dark">
    <div class="container py-4 py-lg-5">
        {{
            component("menu", {
                page: page,
                url: "/portfolio",
                main: main,
                title: "Robert Willemelis",
                subtitle: "Projekte, Hackathons, Konferenzen und Workshops.",
                state: "in Arbeit",
                views: [{ key: 'cards', label: '▦ Cards'}, { key: 'list', label: '☰ Liste' }]
            })
        }}
        {% set upcomingEvents = all.data | getUpcomingEvents(build.now) %}
        <section search-context>
            
    <nav class="portfolio-toolbar mb-4  z-2 position-relative" aria-label="Portfolio Filter">
        <div class="row g-3 align-items-center">
            <div class="col-12 col-lg-8">
                {{
                    component("search", {
                        label: "Portfolio durchsuchen",
                        class: "portfolio-input",
                        placeholder: "grep: Titel, Ort, Status, Tags …"
                    })
                }}
            </div>
            <div class="col-12 col-lg-4 portfolio-actions mt-0">
                {{
                    component("dropdown", {
                        values: [ 'date-desc','date-asc', 'title-asc', 'title-desc', 'status-asc', 'status-desc'],
                        defaultValue: "date-desc",
                        key: "bs-sort",
                        label: "Sortierung",
                        sort: "[data-category-section]"
                    })
                }}
            </div>
            <div class="col-12 col-lg-12">
                <div class="portfolio-filter-scroll gap-2 justify-content-lg-end" data-category-filter>
                    {{
                        component("filter-button", {
                            key: "all",
                            label: "Alle",
                            css: 'mb-2',
                            length: categories | length
                        })
                    }}
                    {{
                        component("filter-button", {
                            key: "upcoming",
                            label: "Upcoming",
                            css: 'mb-2',
                            length: upcomingEvents | length
                        })
                    }}
                    {% for category in categories %}
                        {{
                            component("filter-button", {
                                key: category,
                                label: categoryLabels[category] | default(category),
                                css: 'mb-2',
                                length: all.data[category] | length
                            })
                        }}
                    {% endfor %}
                </div>
            </div>
        </div>
    </nav>
    
    {% if upcomingEvents | length %}
    
        <section class="portfolio-upcoming portfolio-section mb-5" aria-labelledby="upcoming-events-title" data-category-section="upcoming">
            <div class="portfolio-category-head d-flex align-items-end justify-content-between gap-3 mb-3">
                <div>
                    <p class="portfolio-kicker mb-1">next up</p>
                    <h2 class="h4 mb-0" id="upcoming-events-title">Upcoming Events</h2>
                </div>
                <span class="portfolio-count"><span data-count>{{ upcomingEvents | length }}</span> geplant</span>
            </div>

            <div class="portfolio-upcoming-list" data-upcoming-list>
                {% for event in upcomingEvents %}
                    <article
                        class="portfolio-upcoming-item alert alert-secondary py-2 px-3 mb-2 d-flex align-items-center gap-2 flex-wrap"
                        data-upcoming-item
                        data-search-item
                        data-category="{{ event.category }}"
                        data-search="{{ event | getSearchValue('') }}"
                        data-title="{{ event.title | lower }}"
                        data-status="{{ event.status | lower }}"
                        data-start="{{ event.start }}"
                        data-pinned="{% if event.pinned %}1{% else %}0{% endif %}"
                        data-event-start="{{ event.start }}">

                        {{ component("badge", { text: event.status, css: "badge text-bg-secondary {{ event.statusClass }}" }) }}
                        {{
                            component("image", {
                                image: event.logo,
                                class: "",
                                width: "30",
                                height: "30",
                                height: "auto",
                                placeholder: event.title,
                                lazy: true
                            })
                        }}
                        {{component("text", { text: event | getFullDate })}}
                        &nbsp; - &nbsp;
                        {{ component("text_link", { item: event, tag: 'h3' }) }}  {# TITLE #}
                        
                        (
                            {{ component("flag", { country: event['country'], width: 20 }) }}
                            {{ component("text", { text: event.location})}}
                        )
                    </article>
                {% endfor %}
            </div>  
        </section>
    {% endif %}

    {% for category in categories %}
        <section class="portfolio-category mb-5" data-category-section="{{ category }}">
            <div class="portfolio-category-head d-flex align-items-end justify-content-between gap-3 mb-3">
                <div>
                    <h2 class="h4 mb-0">{{ categoryLabels[category] | default(category) }}</h2>
                </div>
                <span class="portfolio-count"><span data-count>{{ all.data[category] | length }}</span> items</span>
            </div>

            <div class="portfolio-grid">
                {% for item in all.data[category] %}
                    {% set statusClass = statusClasses[item.status] | default('text-bg-secondary') %}
                    {% set meta = [
                        { key: "date", start: item.start, end: item.end },
                        { key: "loc", value: item.location, flag: item.country },
                        { key: "project", value: item.project },
                        { key: "role", value: item.role },
                        { key: "conductor", value: item.conductor },
                        { key: "type", value: item.type }
                        ] 
                    %}
                    {% set css_link = "btn btn-sm portfolio-link" %}
                    {% set links = [
                        { url: item.url, text: "open ↗", css: css_link, target: "_blank" },
                        { url: item.code, text: "code", css: css_link, target: "_blank" },
                        { url: item.video, text: "video", css: css_link, target: "_blank" },
                        { url: item.slides, text: "slides", css: css_link, target: "_blank" }
                        ]
                        
                    %}

                        {{ component("card", { item: item, category: category, meta: meta, links: links})}}
                    
                {% endfor %}
            </div>
        </section>
    {% endfor %}

    <p class="portfolio-empty d-none" data-search-empty>Keine passenden Einträge gefunden.</p>
</section>
    </div>
</section>
