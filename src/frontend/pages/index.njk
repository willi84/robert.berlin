---
layout: base.template.njk
title: Welcome to robert.berlin
navigation: true
footer: true
---

{%- from "./../templates/_setup/macros/component.macro.njk" import component -%}



{% set categories = all.categories | default([]) %}
{% set statusClasses = all.configuration.status | default({}) %}
{% set eventCategories = ['hackathons', 'conferences', 'workshops'] %}
{% set categoryLabels = {
    projects: '🗂️ Projekte',
    hackathons: '🚀 Hackathons',
    conferences: '🗓️ Konferenzen',
    workshops: '🎓 Workshops',
    tech: '💻 Tech'
} 
%}

<section class="portfolio-shell" data-portfolio data-view="cards" data-theme="dark">
    <div class="container py-4 py-lg-5">
        <header class="portfolio-header mb-4 z-3 position-relative">
            <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <a class="portfolio-logo" href="/" aria-label="Startseite">
                        {{
                            component("image", {
                                image: main.logo.src,
                                class: "",
                                alt_prefix: main.logo.alt,
                                width: "50%",
                                height: "auto",
                                lazy: true
                            })
                        }}
                    </a>
                    <div>
                        <p class="portfolio-kicker mb-1">~/portfolio</p>
                        <h1 class="portfolio-title mb-1">Robert Willemelis</h1>
                        <p class="portfolio-subtitle mb-0">Projekte, Hackathons, Konferenzen und Workshops.  <span class="badge bg-warning">in Arbeit</span></p>
                    </div>
                </div>

                <div class="portfolio-actions d-flex flex-wrap gap-2">
                    <div class="btn-group btn-group-sm" role="group" aria-label="Ansicht wechseln">
                        <button class="btn btn-outline-light active" type="button" data-view-button="cards">▦ Cards</button>
                        <button class="btn btn-outline-light" type="button" data-view-button="list">☰ Liste</button>
                    </div>
                    {{
                        component("dropdown", {
                            values: [ 'light','green', 'red', 'dark', 'blue', 'yellow'],
                            defaultValue: "dark",
                            key: "bs-theme",
                            label: "Theme"
                        })
                    }}
                    
                </div>
            </div>
        </header>

        {% set upcomingEvents = all.data | getUpcomingEvents(build.now) %}
        <section search-context>
            
    <nav class="portfolio-toolbar mb-4  z-2 position-relative" aria-label="Portfolio Filter">
        <div class="row g-3 align-items-center">
            <div class="col-12 col-lg-8">
                {{
                    component("search", {
                        label: "Portfolio durchsuchen",
                        class: "portfolio-input",
                        placeholder: "grep: Titel, Ort, Status, Tags …"
                    })
                }}
            </div>
            <div class="col-12 col-lg-4 portfolio-actions mt-0">
                {{
                    component("dropdown", {
                        values: [ 'date-desc','date-asc', 'title-asc', 'title-desc', 'status-asc', 'status-desc'],
                        defaultValue: "date-desc",
                        key: "bs-sort",
                        label: "Sortierung",
                        sort: "[data-category-section]"
                    })
                }}
            </div>
            <div class="col-12 col-lg-12">
                <div class="portfolio-filter-scroll gap-2 justify-content-lg-end" data-category-filter>
                    {{
                        component("filter-button", {
                            key: "all",
                            label: "Alle",
                            css: 'mb-2',
                            length: categories | length
                        })
                    }}
                    {{
                        component("filter-button", {
                            key: "upcoming",
                            label: "Upcoming",
                            css: 'mb-2',
                            length: upcomingEvents | length
                        })
                    }}
                    {% for category in categories %}
                        {{
                            component("filter-button", {
                                key: category,
                                label: categoryLabels[category] | default(category),
                                css: 'mb-2',
                                length: all.data[category] | length
                            })
                        }}
                    {% endfor %}
                </div>
            </div>
        </div>
    </nav>
    
    {% if upcomingEvents | length %}
    
        <section class="portfolio-upcoming portfolio-section mb-5" aria-labelledby="upcoming-events-title" data-category-section="upcoming">
            <div class="portfolio-category-head d-flex align-items-end justify-content-between gap-3 mb-3">
                <div>
                    <p class="portfolio-kicker mb-1">next up</p>
                    <h2 class="h4 mb-0" id="upcoming-events-title">Upcoming Events</h2>
                </div>
                <span class="portfolio-count"><span data-count>{{ upcomingEvents | length }}</span> geplant</span>
            </div>

            <div class="portfolio-upcoming-list" data-upcoming-list>
                {% for event in upcomingEvents %}
                    <article
                        class="portfolio-upcoming-item alert alert-secondary py-2 px-3 mb-2 d-flex align-items-center gap-2 flex-wrap"
                        data-upcoming-item
                        data-search-item
                        data-category="{{ event.category }}"
                        data-search="{{ event | getSearchValue('') }}"
                        data-title="{{ event.title | lower }}"
                        data-status="{{ event.status | lower }}"
                        data-start="{{ event.start }}"
                        data-pinned="{% if event.pinned %}1{% else %}0{% endif %}"
                        data-event-start="{{ event.start }}">

                        {{ component("badge", { text: event.status, css: "badge text-bg-secondary {{ event.statusClass }}" }) }}
                        {{
                            component("flag", {
                                country: event['country'],
                                width: 20
                            })
                        }}
                        {{
                            component("image", {
                                image: event.logo,
                                class: "",
                                width: "30",
                                height: "30",
                                height: "auto",
                                placeholder: event.title,
                                lazy: true
                            })
                        }}
                        <span data-search-mark>{{event.start}}</span>{% if event.end is defined and event.end != "" %} - <span data-search-mark>{{ event.end }}</span>{% endif %}
                        &nbsp; - &nbsp;
                        {% if event.url %}
                            {{ component("link", { url: event.url, text: event.title, css: "fw-semibold text-decoration-none", target: "_blank" }) }}
                        {% else %}
                            <strong data-search-mark>{{ event.title }}</strong>
                        {% endif %}
                        
                        
                        
                        {% if event['location'] %}
                            <span>
                                (📍 <span data-search-mark>{{ event['location'] }}</span>)
                            
                            </span>
                        {% endif %}
                        
                    </article>
                {% endfor %}
            </div>  
        </section>
    {% endif %}

    {% for category in categories %}
        <section class="portfolio-category mb-5" data-category-section="{{ category }}">
            <div class="portfolio-category-head d-flex align-items-end justify-content-between gap-3 mb-3">
                <div>
                    <h2 class="h4 mb-0">{{ categoryLabels[category] | default(category) }}</h2>
                </div>
                <span class="portfolio-count"><span data-count>{{ all.data[category] | length }}</span> items</span>
            </div>

            <div class="portfolio-grid">
                {% for item in all.data[category] %}
                    {% set statusClass = statusClasses[item.status] | default('text-bg-secondary') %}


                    <article
                        class="portfolio-item{% if item.pinned %} is-pinned{% endif %}"
                        data-search-item 
                        data-category="{{ item.category }}"
                        data-search="{{ item | getSearchValue(category) }}"
                        data-title="{{ item.title | lower }}"
                        data-status="{{ item.status | lower }}"
                        data-start="{{ item.start }}"
                        data-pinned="{% if item.pinned %}1{% else %}0{% endif %}">
                        <div class="portfolio-visual">
                            {% if item.screenshot %}
                            <a href="{{ item.url or item.screenshot }}" {% if url %}target="_blank" rel="noopener noreferrer"{% endif %} aria-label="{{ item.title }} öffnen">
                                {{
                                    component("image", {
                                        image: item.screenshot,
                                        css: "portfolio-screenshot",
                                        height: "auto",
                                        width: "30",
                                        alt: "Screenshot von {{ item.title }}",
                                        placeholder: item.title,
                                        lazy: true
                                    })
                                }}
                            </a>
                            {% else %}
                                <div class="portfolio-iconbox" aria-hidden="true">
                                    {{
                                        component("image", {
                                            image: item.icon,
                                            height: "auto",
                                            width: "30",
                                            placeholder: item.title,
                                            lazy: true
                                        })
                                    }}
                                </div>
                            {% endif %}
                        </div>

                        <div class="portfolio-content">
                            <div class="portfolio-item-top">
                                <div class="min-w-0">
                                    <p class="portfolio-path mb-1"  data-search-mark>{{ category }}/{{ item.name | lower | replace(' ', '-') }}</p>
                                    <h3 class="portfolio-item-title mb-0"  data-search-mark>{{ item.title }}</h3>
                                </div>
                                {% if item.pinned == "TRUE" %}
                                    <span class="portfolio-pin" title="Hervorgehoben">📌</span>
                                {% endif %}
                            </div>

                            <div class="portfolio-badges">
                                 {{ component("badge", { text: item.status, css: statusClass }) }}
                                 {{ component("badge", { text: item.prize, css: "text-bg-success", prefix: "🏆" }) }}
                                 {{ component("badge", { text: item.tags, css: "portfolio-muted-badge" }) }}
                            </div>

                            {% if item.description %}
                                <p class="portfolio-description">{{ item.description }}</p>
                            {% endif %}

                            <dl class="portfolio-meta">
                                {{ component("key_value", { key: "date", start: item.start, end: item.end }) }}
                                {{ component("key_value", { key: "loc", value: item.location, flag: item.country }) }}
                                {{ component("key_value", { key: "project", value: item.project }) }}
                                {{ component("key_value", { key: "role", value: item.role }) }}
                                {{ component("key_value", { key: "conductor", value: item.conductor }) }}
                                {{ component("key_value", { key: "type", value: item.type }) }}
                            </dl>

                            <div class="portfolio-links">
                                {% set css_link = "btn btn-sm portfolio-link" %}
                                {{ component("link", { url: item.url, text: "open ↗", css: css_link, target: "_blank" }) }}
                                {{ component("link", { url: item.code, text: "code", css: css_link, target: "_blank" }) }}
                                {{ component("link", { url: item.video, text: "video", css: css_link, target: "_blank" }) }}
                                {{ component("link", { url: item.slides, text: "slides", css: css_link, target: "_blank" }) }}
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        </section>
    {% endfor %}

    <p class="portfolio-empty d-none" data-search-empty>Keine passenden Einträge gefunden.</p>
</section>
    </div>
</section>
