<div class="container my-5 text-center">
    {% for link in main.links %}
    {% set disabled = (link.disabled is defined and link.disabled == true) or (link.url is not defined) %}
        {{
            component("button_link", {
                "type": link.type or "link",
                "text": link.text,
                "url": link.url,
                "image_before": link.image_before,
                "image_after": link.image_after,
                "size": link.size,
                "target": link.target,
                "disabled": disabled
            })
        }}
    {% endfor %}
</div>
<div class="flex">
    {# <img width="1200" height="800" id="logo" src="./assets/logo.jpg" /> #}
    {{
           component("image", {
             image: main.logo.src,
             class: "",
             alt_prefix: main.logo.alt,
             width: "1200",
             height: "auto",
             lazy: true
           })
         }}
</div>